@tool
extends EditorScript

const BOARD_PNG = "res://Sprites/nathan-mcguire-got-westerosmap.jpg"
const SCENE_OUT = "res://Scenes/BoardMap.tscn"

# Sprite3D.pixel_size = 0.01 (Godot default)
# SVG: 1920x3840 px -> world: 19.2 x 38.4 units
# world_x = (svg_x - 960) * 0.01
# world_z = (svg_y - 1920) * 0.01
# All coordinates below are pre-scaled for pixel_size = 0.01

func _run():
	if not DirAccess.dir_exists_absolute(ProjectSettings.globalize_path("res://Scenes/")):
		DirAccess.make_dir_recursive_absolute(ProjectSettings.globalize_path("res://Scenes/"))

	var root := Node3D.new()
	root.name = "BoardMap"

	var sprite := Sprite3D.new()
	sprite.name = "Sprite3D"
	var board_tex: Texture2D = load(BOARD_PNG)
	if board_tex:
		sprite.texture = board_tex
	else:
		push_warning("Board PNG not found: " + BOARD_PNG)
	sprite.pixel_size = 0.01
	sprite.rotation_degrees.x = -90.0
	root.add_child(sprite)
	sprite.owner = root

	var regions_node := Node3D.new()
	regions_node.name = "Regions"
	root.add_child(regions_node)
	regions_node.owner = root

	var built := 0
	var data := _get_region_data()
	for display_name in data.keys():
		var entry: Dictionary = data[display_name]
		var area := Area3D.new()
		area.name = display_name
		area.position = Vector3(entry.world_x, 0.0, entry.world_z)
		regions_node.add_child(area)
		area.owner = root
		var polygons: Array = entry.polygons
		for i in polygons.size():
			var col := CollisionPolygon3D.new()
			col.name = "CollisionPolygon3D" if i == 0 else "CollisionPolygon3D_%d" % i
			col.polygon = polygons[i]
			col.depth = 0.1
			col.rotation_degrees.x = 90.0
			area.add_child(col)
			col.owner = root
		built += 1

	var scene := PackedScene.new()
	scene.pack(root)
	ResourceSaver.save(scene, SCENE_OUT)
	root.queue_free()
	print("BoardMap.tscn saved with %d regions." % built)

